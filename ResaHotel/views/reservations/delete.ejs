<!-- views/reservations/delete.ejs -->
<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/semantic-ui/2.5.0/semantic.min.css">
    <link rel="stylesheet" href="/style.css">
</head>

<body>
<%- include('../partials/navigation') %>

    <!-- Contenu principal -->
    <div style="padding-top: 100px; min-height: 100vh; background: #f5f5f5;">
        <div class="ui container" style="max-width: 800px; padding: 3rem 0;">
            
            <!-- Breadcrumb -->
            <div class="ui breadcrumb">
                <a href="/" class="section">Accueil</a>
                <div class="divider"> / </div>
                <a href="/reservations" class="section">Réservations</a>
                <div class="divider"> / </div>
                <div class="active section">Supprimer</div>
            </div>

            <!-- Message d'avertissement -->
            <div class="ui negative message" style="margin-top: 2rem;">
                <div class="header">
                    <i class="exclamation triangle icon"></i>
                    ⚠️ Supprimer cette réservation ?
                </div>
                <p>Cette action est irréversible. Êtes-vous sûr de vouloir supprimer cette réservation ?</p>
            </div>

            <!-- Détails de la réservation -->
            <div class="ui segment" style="margin-top: 2rem;">
                <h3 class="ui header">
                    <i class="calendar times icon"></i>
                    <div class="content">
                        Détails de la réservation #<%= reservation.id %>
                    </div>
                </h3>
                
                <div class="ui divider"></div>

                <div class="ui relaxed list" style="font-size: 1.1em;">
                    <div class="item" style="padding: 10px 0;">
                        <i class="user icon"></i>
                        <div class="content">
                            <div class="header">Client</div>
                            <div class="description"><%= reservation.client_nom %></div>
                        </div>
                    </div>

                    <div class="item" style="padding: 10px 0;">
                        <i class="mail icon"></i>
                        <div class="content">
                            <div class="header">Email</div>
                            <div class="description"><%= reservation.client_email %></div>
                        </div>
                    </div>

                    <div class="item" style="padding: 10px 0;">
                        <i class="phone icon"></i>
                        <div class="content">
                            <div class="header">Téléphone</div>
                            <div class="description"><%= reservation.client_telephone %></div>
                        </div>
                    </div>

                    <div class="item" style="padding: 10px 0;">
                        <i class="bed icon"></i>
                        <div class="content">
                            <div class="header">Chambre</div>
                            <div class="description">
                                <div class="ui violet label">
                                    Chambre <%= reservation.chambre_numero %> 
                                    <div class="detail"><%= reservation.chambre_capacite %> pers.</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="item" style="padding: 10px 0;">
                        <i class="calendar icon"></i>
                        <div class="content">
                            <div class="header">Date d'arrivée</div>
                            <div class="description"><%= new Date(reservation.date_arrivee).toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></div>
                        </div>
                    </div>

                    <div class="item" style="padding: 10px 0;">
                        <i class="calendar icon"></i>
                        <div class="content">
                            <div class="header">Date de départ</div>
                            <div class="description"><%= new Date(reservation.date_depart).toLocaleDateString('fr-FR', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></div>
                        </div>
                    </div>

                    <div class="item" style="padding: 10px 0;">
                        <i class="clock icon"></i>
                        <div class="content">
                            <div class="header">Durée du séjour</div>
                            <div class="description">
                                <% 
                                    const dateArrivee = new Date(reservation.date_arrivee);
                                    const dateDepart = new Date(reservation.date_depart);
                                    const duree = Math.ceil((dateDepart - dateArrivee) / (1000 * 60 * 60 * 24));
                                %>
                                <%= duree %> nuit<%= duree > 1 ? 's' : '' %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Formulaire de confirmation -->
            <form action="/reservations/delete/<%= reservation.id %>" method="POST" style="margin-top: 2rem; text-align: center;">
                <button type="submit" class="ui red large button">
                    <i class="trash icon"></i>
                    Confirmer la suppression
                </button>
                <a href="/reservations" class="ui large button">
                    <i class="cancel icon"></i>
                    Annuler
                </a>
            </form>
        </div>
    </div>

    <!-- Footer -->
    <div class="footer" style="margin-top: 3rem;">
        <div class="ui container">
            <div class="ui four column stackable grid">
                <div class="column">
                    <h4>À Propos</h4>
                    <p>Hôtel California, votre destination de luxe pour des séjours inoubliables.</p>
                </div>
                <div class="column">
                    <h4>Liens Rapides</h4>
                    <div class="ui link list">
                        <a href="/chambres/disponibles" class="item">Nos Chambres</a>
                        <a href="/service" class="item">Service</a>
                        <a href="/contact" class="item">Contact</a>
                        <a href="/clients" class="item">Client</a>
                    </div>
                </div>
                <div class="column">
                    <h4>Contact</h4>
                    <p>📍 30 r Louise Michel, 38000 Grenoble<br>
                        📞 04 38 12 36 00<br>
                        📧 Kwentinsaundev@hotelcalifornia.fr</p>
                </div>
                <div class="column">
                    <h4>Suivez-nous</h4>
                    <div class="ui huge icons social-icons">
                        <a href="https://www.facebook.com/login.php" target="_blank">
                            <i class="facebook icon"></i>
                        </a>
                        <a href="https://www.instagram.com">
                            <i class="instagram icon"></i>
                        </a>
                        <a href="https://x.com">
                            <i class="x icon"></i>
                        </a>
                    </div>
                </div>
            </div>
            <div class="ui divider"></div>
            <div class="footer-bottom">
                <p>© 2025 Hôtel California. Tous droits réservés.</p>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/semantic-ui/2.5.0/semantic.min.js"></script>
</body>

</html>