<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/semantic-ui/2.5.0/semantic.min.css">
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <%- include('../partials/navigation') %>

    <!-- Hero -->
    <div class="clients-hero" style="padding-top: 100px; padding-bottom: 30px; padding-left: 2rem;">
        <div class="ui container">
            <h1 class="clients-hero h1">
                <i class="address book icon" style="color: #667eea;"></i>
                Gestion des Contacts
            </h1>
            <p>Gérez vos partenaires et fournisseurs</p>
        </div>
    </div>

    <!-- Contenu principal -->
    <div class="ui container" style="margin-top: 2rem; margin-bottom: 80px;">

        <!-- Bouton ajouter -->
        <a href="/contact/create" class="ui primary button" style="margin-bottom: 1.5rem; display: inline-block;">
            <i class="plus icon"></i> Ajouter un contact
        </a>

        <!-- Tableau -->
        <div class="clients-table-container">
            <h2 style="margin: 0 0 16px 0; font-size: 1.1rem; color: #111827;">
                <i class="list icon" style="color: #667eea;"></i> Liste des contacts
            </h2>

            <% if (contacts.length === 0) { %>
                <div class="empty-state">
                    <div style="font-size: 2.5rem; margin-bottom: 12px; color: #d1d5db;">
                        <i class="inbox icon"></i>
                    </div>
                    <h3>Aucun contact trouvé</h3>
                    <p>Commencez par ajouter votre premier contact</p>
                </div>
            <% } else { %>
                <table class="clients-table">
                    <thead>
                        <tr>
                            <th style="width: 60px;"></th>
                            <th>Nom / Entreprise</th>
                            <th>Email</th>
                            <th>Téléphone</th>
                            <th>Type</th>
                            <th style="width: 180px; text-align: right;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% contacts.forEach(c => { %>
                            <tr>
                                <td>
                                    <div class="client-avatar">
                                        <%= (c.nom_entreprise || c.nom).charAt(0).toUpperCase() %>
                                    </div>
                                </td>
                                <td>
                                    <strong><%= c.nom_entreprise || c.nom %></strong>
                                </td>
                                <td style="color: #6b7280;"><%= c.email %></td>
                                <td style="color: #6b7280;"><%= c.telephone %></td>
                                <td>
                                    <% if (c.type_sponsor) { %>
                                        <span class="ui tiny label" style="background: #ede9fe; color: #5b21b6; border: none;">
                                            <%= c.type_sponsor %>
                                        </span>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <a class="ui mini primary button" href="/contact/<%= c.id %>/edit">
                                            <i class="edit icon"></i> Modifier
                                        </a>
                                        <a class="ui mini red button" href="/contact/<%= c.id %>/delete">
                                            <i class="trash icon"></i> Supprimer
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </div>

    <!-- Footer -->
    <div class="footer">
        <div class="ui container">
            <div class="ui four column stackable grid">
                <div class="column">
                    <h4>À Propos</h4>
                    <p>Hôtel California, votre destination de luxe pour des séjours inoubliables.</p>
                </div>
                <div class="column">
                    <h4>Liens Rapides</h4>
                    <div class="ui link list">
                        <a href="/chambres/disponibles" class="item">Nos Chambres</a>
                        <a href="/service" class="item">Service</a>
                        <a href="/contact" class="item">Contact</a>
                        <a href="/clients" class="item">Client</a>
                    </div>
                </div>
                <div class="column">
                    <h4>Contact</h4>
                    <p>
                        <i class="map marker alternate icon"></i> 30 r Louise Michel, 38000 Grenoble<br>
                        <i class="phone icon"></i> 04 38 12 36 00<br>
                        <i class="mail icon"></i> contact@hotelcalifornia.fr
                    </p>
                </div>
                <div class="column">
                    <h4>Suivez-nous</h4>
                    <div class="ui huge icons social-icons">
                        <a href="https://www.facebook.com" target="_blank"><i class="facebook icon"></i></a>
                        <a href="https://www.instagram.com" target="_blank"><i class="instagram icon"></i></a>
                        <a href="https://x.com" target="_blank"><i class="x icon"></i></a>
                    </div>
                </div>
            </div>
            <div class="ui divider"></div>
            <div class="footer-bottom">
                <p>© 2025 Hôtel California. Tous droits réservés.</p>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/semantic-ui/2.5.0/semantic.min.js"></script>
</body>
</html>
